NODE_ENV=development
PORT=4000

# Database
DATABASE_URL=postgresql://telemantix:password@localhost:5432/telemantix

# Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_ACCESS_SECRET=your_access_secret_here_min_32_chars
JWT_REFRESH_SECRET=your_refresh_secret_here_min_32_chars

# CORS
CORS_ORIGIN=http://localhost:5173

# Meta / Facebook
META_APP_ID=your_meta_app_id
META_APP_SECRET=your_meta_app_secret
META_VERIFY_TOKEN=your_webhook_verify_token

# WhatsApp Cloud API
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id
WHATSAPP_BUSINESS_ACCOUNT_ID=your_waba_id
WHATSAPP_API_TOKEN=your_whatsapp_token

# Exotel (IVR)
EXOTEL_API_KEY=your_exotel_key
EXOTEL_API_TOKEN=your_exotel_token
EXOTEL_SID=your_exotel_sid

# SendGrid
SENDGRID_API_KEY=your_sendgrid_key
SENDGRID_FROM_EMAIL=noreply@telemantix.io

# Resend (alternative to SendGrid)
RESEND_API_KEY=your_resend_key

# Google Ads
GOOGLE_ADS_CLIENT_ID=your_google_client_id
GOOGLE_ADS_CLIENT_SECRET=your_google_client_secret
GOOGLE_ADS_DEVELOPER_TOKEN=your_developer_token

# IndiaMART
INDIAMART_API_KEY=your_indiamart_key

# Web Push
VAPID_PUBLIC_KEY=your_vapid_public_key
VAPID_PRIVATE_KEY=your_vapid_private_key
VAPID_SUBJECT=mailto:admin@telemantix.io

# App URL
APP_URL=http://localhost:4000
FRONTEND_URL=http://localhost:5173

# Super Admin
SUPER_ADMIN_JWT_SECRET=your_super_admin_jwt_secret_min_32_chars

# Encryption
ENCRYPTION_KEY=telemantix-32-char-encryption-key

# AI
ANTHROPIC_API_KEY=
